.container {
  min-height: 100vh;
  background: #f5f5f5;
}
.video-section {
  width: 100%;
  background: #000;
}
.video-player {
  width: 100%;
  height: 225px;
}
.course-info {
  padding: 20px;
  background: #fff;
}
.course-title {
  font-size: 20px;
  font-weight: bold;
  color: #333;
  margin-bottom: 12px;
}
.course-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}
.tag {
  background: #e6f7ff;
  color: #1890ff;
  padding: 4px 12px;
  border-radius: 4px;
  font-size: 12px;
}
.duration {
  color: #999;
  font-size: 14px;
}
.course-desc {
  color: #666;
  font-size: 14px;
  line-height: 1.6;
}
.action-bar {
  padding: 20px;
  background: #fff;
}
.btn-study {
  background: #1890ff;
  color: #fff;
  border-radius: 8px;
  font-size: 16px;
}