page { background: #f5f5f5; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
.container { padding: 24rpx; }
.welcome-card { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 24rpx; padding: 40rpx 32rpx; margin-bottom: 24rpx; }
.welcome-text { font-size: 28rpx; opacity: 0.9; }
.welcome-name { font-size: 48rpx; font-weight: bold; margin-top: 12rpx; }
.quick-actions { display: flex; justify-content: space-around; background: white; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; }
.action-item { text-align: center; }
.action-icon { font-size: 56rpx; margin-bottom: 12rpx; }
.action-text { font-size: 26rpx; color: #666; }
.stats-card { background: white; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; }
.stats-title { font-size: 32rpx; font-weight: bold; margin-bottom: 24rpx; }
.stats-row { display: flex; justify-content: space-around; }
.stat-item { text-align: center; }
.stat-value { font-size: 48rpx; color: #1890ff; font-weight: bold; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.section { margin-bottom: 24rpx; }
.section-title { font-size: 32rpx; font-weight: bold; margin-bottom: 20rpx; }
.course-list { background: white; border-radius: 24rpx; overflow: hidden; }
.course-item { padding: 28rpx 32rpx; border-bottom: 1rpx solid #f0f0f0; }
.course-title { font-size: 30rpx; font-weight: bold; color: #333; }
.course-desc { font-size: 26rpx; color: #888; margin-top: 10rpx; }
.course-meta { display: flex; gap: 16rpx; margin-top: 14rpx; }
.course-duration { font-size: 24rpx; color: #1890ff; }
.course-category { font-size: 22rpx; background: #e6f7ff; color: #1890ff; padding: 4rpx 12rpx; border-radius: 8rpx; }
.notice-list { background: white; border-radius: 24rpx; overflow: hidden; }
.notice-item { padding: 28rpx 32rpx; border-bottom: 1rpx solid #f0f0f0; }
.notice-title { font-size: 30rpx; font-weight: bold; color: #333; display: flex; align-items: center; gap: 10rpx; }
.notice-tag { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 6rpx; color: white; flex-shrink: 0; }
.notice-brief { font-size: 26rpx; color: #888; margin-top: 10rpx; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 1; overflow: hidden; }
.notice-full { font-size: 26rpx; color: #666; margin-top: 10rpx; line-height: 1.8; padding: 16rpx 20rpx; background: #f9f9f9; border-radius: 12rpx; }
.category-tabs { display: flex; background: white; padding: 24rpx 0; margin-bottom: 24rpx; border-radius: 24rpx; overflow-x: auto; }
.tab-item { flex-shrink: 0; padding: 14rpx 32rpx; font-size: 28rpx; color: #666; border-radius: 40rpx; margin: 0 12rpx; }
.tab-item.active { background: #1890ff; color: white; }
.course-card { background: white; border-radius: 24rpx; padding: 28rpx; margin-bottom: 20rpx; }
.course-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.course-tag { font-size: 22rpx; background: #e6f7ff; color: #1890ff; padding: 6rpx 16rpx; border-radius: 8rpx; }
.course-footer { display: flex; justify-content: space-between; margin-top: 16rpx; }
.duration { font-size: 24rpx; color: #666; }
.status { font-size: 24rpx; color: #52c41a; }
.paper-card { background: white; border-radius: 24rpx; padding: 32rpx; margin-bottom: 20rpx; }
.paper-title { font-size: 32rpx; font-weight: bold; color: #333; }
.paper-desc { font-size: 26rpx; color: #888; margin-top: 12rpx; }
.paper-info { display: flex; gap: 24rpx; margin-top: 20rpx; font-size: 24rpx; color: #666; }
.start-btn { background: #1890ff; color: white; border-radius: 40rpx; margin-top: 20rpx; font-size: 28rpx; }
.user-card { display: flex; align-items: center; background: white; border-radius: 24rpx; padding: 40rpx 32rpx; margin-bottom: 24rpx; }
.avatar { font-size: 80rpx; margin-right: 24rpx; }
.nickname { font-size: 36rpx; font-weight: bold; }
.username { font-size: 26rpx; color: #999; margin-top: 8rpx; }
.login-btn { background: #1890ff; color: white; border-radius: 40rpx; margin: 0 32rpx; }
.menu-list { background: white; border-radius: 24rpx; overflow: hidden; }
.menu-item { display: flex; align-items: center; padding: 32rpx; border-bottom: 1rpx solid #f5f5f5; }
.menu-icon { font-size: 40rpx; margin-right: 20rpx; }
.menu-text { flex: 1; font-size: 30rpx; color: #333; }
.menu-arrow { font-size: 36rpx; color: #ccc; }
.notice-card { background: white; border-radius: 24rpx; padding: 28rpx; margin-bottom: 20rpx; }
.notice-header { display: flex; justify-content: space-between; margin-bottom: 14rpx; }
.notice-type { font-size: 24rpx; background: #fff7e6; color: #fa8c16; padding: 6rpx 16rpx; border-radius: 8rpx; }
.notice-time { font-size: 24rpx; color: #999; }
.empty { text-align: center; padding: 80rpx; color: #999; font-size: 28rpx; }