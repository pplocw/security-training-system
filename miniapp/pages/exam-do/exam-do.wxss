.container { padding: 20rpx; }
.paper-title { font-size: 36rpx; font-weight: bold; text-align: center; margin-bottom: 20rpx; }
.timer { text-align: center; color: #ff4d4f; margin-bottom: 30rpx; font-size: 28rpx; }
.question-item { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1); }
.q-title { font-size: 30rpx; margin-bottom: 16rpx; }
.option { padding: 16rpx 24rpx; margin: 8rpx 0; border: 2rpx solid #ddd; border-radius: 8rpx; transition: all 0.2s; }
.option:active { opacity: 0.7; }
.option.selected { background: #e6f7ff; border-color: #1890ff; color: #1890ff; font-weight: bold; position: relative; }
.option.selected::before { content: "✓ "; font-weight: bold; }
.submit-btn { margin-top: 40rpx; background: #1890ff; color: #fff; border-radius: 12rpx; }
