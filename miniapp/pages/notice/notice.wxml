<view class="container">
  <view class="notice-list">
    <view class="notice-card" wx:for="{{notices}}" wx:key="id">
      <view class="notice-header">
        <view class="notice-type">
          <text wx:if="{{item.type === \"training\"}}">培训通知</text>
          <text wx:else>系统消息</text>
        </view>
        <view class="notice-time">{{item.createTime}}</view>
      </view>
      <view class="notice-title">{{item.title}}</view>
      <view class="notice-content">{{item.content}}</view>
    </view>
  </view>

  <view class="empty" wx:if="{{notices.length === 0}}">
    暂无通知
  </view>
</view>