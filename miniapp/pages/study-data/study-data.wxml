<view class="container">
  <!-- 概览卡片 -->
  <view class="overview-card">
    <view class="overview-left">
      <view class="overview-avatar">{{userInfo.avatar || '👤'}}</view>
      <view class="overview-info">
        <view class="overview-name">{{userInfo.nickname || userInfo.username || '未登录'}}</view>
        <view class="overview-sub">{{userInfo.role === 'admin' ? '管理员' : '普通员工'}}</view>
      </view>
    </view>
    <view class="overview-badge">
      <text class="badge-level">{{stats.level}}</text>
      <text class="badge-desc">学习等级</text>
    </view>
  </view>

  <!-- 统计指标 -->
  <view class="stats-grid">
    <view class="stat-item">
      <view class="stat-num">{{stats.totalHours}}</view>
      <view class="stat-label">累计学习(小时)</view>
    </view>
    <view class="stat-item">
      <view class="stat-num">{{stats.courseCount}}</view>
      <view class="stat-label">已学课程</view>
    </view>
    <view class="stat-item">
      <view class="stat-num">{{stats.examCount}}</view>
      <view class="stat-label">已完成考试</view>
    </view>
  </view>

  <!-- 学习进度 -->
  <view class="section">
    <view class="section-title">课程进度</view>
    <view class="course-progress-list">
      <view class="progress-item" wx:for="{{courses}}" wx:key="id">
        <view class="progress-info">
          <view class="progress-name">{{item.title}}</view>
          <view class="progress-meta">{{item.duration}}分钟 · {{item.category}}</view>
        </view>
        <view class="progress-right">
          <view class="progress-bar-wrap">
            <view class="progress-bar" style="width: {{item.progress}}%"></view>
          </view>
          <text class="progress-pct">{{item.progress}}%</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 考试记录 -->
  <view class="section">
    <view class="section-title">考试记录</view>
    <view class="exam-record-list">
      <view class="exam-item" wx:for="{{examRecords}}" wx:key="id">
        <view class="exam-left">
          <view class="exam-name">{{item.paperTitle}}</view>
          <view class="exam-time">{{item.examTime}}</view>
        </view>
        <view class="exam-score {{item.score >= 60 ? 'pass' : 'fail'}}">{{item.score}}分</view>
      </view>
    </view>
  </view>

  <!-- 成就勋章 -->
  <view class="section">
    <view class="section-title">我的成就</view>
    <view class="badge-list">
      <view class="badge-item" wx:for="{{badges}}" wx:key="id">
        <view class="badge-icon">{{item.icon}}</view>
        <view class="badge-name">{{item.name}}</view>
      </view>
    </view>
  </view>
</view>