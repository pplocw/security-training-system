<view class="container">
  <view class="user-card">
    <view class="avatar">👤</view>
    <view class="user-info">
      <view class="nickname">{{userInfo.nickname || "未登录"}}</view>
      <view class="username">{{userInfo.username || ""}}</view>
    </view>
  </view>

  <button class="login-btn" bindtap="onLogin" wx:if="{{!userInfo || !userInfo.username}}">
    点击登录
  </button>

  <view class="menu-list" wx:if="{{userInfo && userInfo.username}}">
    <view class="menu-item" bindtap="onMenuItemTap" data-idx="0">
      <text class="menu-icon">📊</text>
      <text class="menu-text">学习数据</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuItemTap" data-idx="1">
      <text class="menu-icon">🏆</text>
      <text class="menu-text">证书中心</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuItemTap" data-idx="2">
      <text class="menu-icon">⭐</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuItemTap" data-idx="3">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>