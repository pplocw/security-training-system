/* 全局样式 - 符合WCAG 2.1 AA标准 */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

/* 主色调 - 企业级蓝灰 */
.primary-color {
  color: #1a73e8;
}

.primary-bg {
  background-color: #1a73e8;
}

/* 容器 */
.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* 卡片组件 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 24rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #1a73e8 0%, #4285f4 100%);
  color: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  background: #f3f4f6;
  color: #374151;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.tag-blue {
  background: #e8f0fe;
  color: #1a73e8;
}

.tag-green {
  background: #e6f4ea;
  color: #137333;
}

.tag-orange {
  background: #fef7e0;
  color: #b45309;
}

.tag-red {
  background: #fce8e6;
  color: #c5221f;
}

/* 进度条 */
.progress-bar {
  height: 8rpx;
  background: #e5e7eb;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1a73e8 0%, #34a853 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #e5e7eb;
  margin: 24rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  color: #d1d5db;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.list-item:last-child {
  border-bottom: none;
}

/* 安全间距 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
